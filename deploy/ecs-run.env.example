# ECS 部署环境变量模板
# 用法：
#   cp ecs-run.env.example ecs-run.env
#   nano ecs-run.env          # 填入真实密钥（勿提交 Git）
#   set -a && source ecs-run.env && set +a
#   ./ecs-run.sh

# 必填
DASHSCOPE_API_KEY=sk-你的百炼密钥
JWT_SECRET=请用-openssl-rand-hex-32-生成
MASTER_SECRET=请用-openssl-rand-hex-32-生成另一个值

# GitHub MCP（建议配置）
GITHUB_TOKEN=ghp_或github_pat_你的Token
GITHUB_DEFAULT_REPO=LS-crypto/agent

# 跨域（Nginx 同域部署填 http://118.178.144.109）
CORS_ORIGINS=http://118.178.144.109

# J2/J3 可选
# USER_ALLOWED_MODELS=qwen3.6-flash
# MAX_REGISTERED_USERS=100
# MAX_CONCURRENT_CHATS=10

# 可选：Brave 联网搜索
# BRAVE_API_KEY=BSA_xxx

# 可选：端口（默认 8081）
# HOST_PORT=8081
