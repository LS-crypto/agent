# 管理员专用账号（启动时自动创建/提升，勿提交真实密码到 Git）
# ADMIN_EMAIL=admin@example.com
# ADMIN_PASSWORD=你的强密码至少8位

# 多用户加密（必填，生产环境请用随机串）
# JWT_SECRET=openssl-rand-hex-32
# MASTER_SECRET=openssl-rand-hex-32-另一个值

DASHSCOPE_API_KEY=sk-你的百炼密钥

# 默认模型 tier：plus → qwen3.7-plus（见 core/config.py）
# DEFAULT_MODEL_TIER=plus

# 后端 CORS（生产部署时配置，逗号分隔前端域名）
# CORS_ORIGINS=https://118.178.144.109:8081

# 服务
# HOST=0.0.0.0
# PORT=8765
# UVICORN_RELOAD=0

# 前端生产构建（apps/web/.env.production）
# VITE_API_BASE=http://118.178.144.109:8081/api

# MCP（可选）
# MCP_BUILTIN=1
# MCP_BUILTIN_HOST=127.0.0.1
# MCP_BUILTIN_PORT=9000
# MCP_HTTP_URL=http://127.0.0.1:9000

# Agent 权限默认档位：conservative | balanced | permissive
# DEFAULT_PERMISSION_TIER=balanced

# ---------- 阶段 G：外部 MCP（可选）----------

# GitHub — Issues / PR / 代码搜索
# 创建 Fine-grained 或 classic PAT，至少勾选 repo 读权限
# GITHUB_TOKEN=ghp_你的token
# GITHUB_DEFAULT_REPO=owner/repo

# Brave Search — 联网搜索（https://brave.com/search/api/）
# BRAVE_API_KEY=BSA_你的key
# BRAVE_SEARCH_COUNT=5

# J2：普通用户默认可选模型见 core/models/catalog.py DEFAULT_USER_MODEL_IDS
# 覆盖示例（逗号分隔，留空则用默认白名单）：
# USER_ALLOWED_MODELS=qwen3.6-flash,qwen3.7-plus,deepseek-v4-pro,glm-5.2,qwen3-vl-plus

# 打开本机文件夹（阶段 N3；本地/桌面版开启，公网 ECS 保持关闭）
ALLOW_LOCAL_FOLDER=1

# 云端工作区 zip 上传（ECS 替代「打开本机文件夹」；默认开启）
# WORKSPACE_UPLOAD_ENABLED=1
# WORKSPACE_UPLOAD_MAX_ZIP_BYTES=52428800
# WORKSPACE_UPLOAD_MAX_FILES=2000
# WORKSPACE_UPLOAD_MAX_FILE_BYTES=10485760
# USER_WORKSPACE_QUOTA_BYTES=104857600

# Web 聊天发图（视觉模型）
# CHAT_MAX_IMAGES=4
# CHAT_MAX_IMAGE_BYTES=5242880
# DEFAULT_VISION_MODEL=qwen3-vl-flash
